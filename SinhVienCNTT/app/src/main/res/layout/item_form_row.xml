<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingTop="10dp"
    android:paddingBottom="10dp">

    <FrameLayout
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="12dp">

        <View
            android:id="@+id/form_icon_bg"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_circle" />

        <ImageView
            android:id="@+id/iv_form_icon"
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_grade"
            android:contentDescription="Form" />

    </FrameLayout>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/tv_form_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Đơn xin nghỉ học"
            android:textColor="@color/text_primary"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_form_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mẫu BM-01"
            android:textColor="@color/text_hint"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="→"
        android:textColor="@color/text_hint"
        android:textSize="18sp" />

</LinearLayout>
