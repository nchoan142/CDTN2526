<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- Header -->
    <FrameLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_gradient_header">

        <View
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:layout_gravity="end|top"
            android:layout_marginEnd="-30dp"
            android:layout_marginTop="-30dp"
            android:background="@drawable/bg_splash_circle"
            android:alpha="0.12" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="16dp"
            android:layout_marginTop="16dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/btn_back"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:padding="12dp"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thời Khoá Biểu"
                    android:textColor="#FFFFFF"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Học kỳ 2 — Năm học 2025-2026"
                    android:textColor="#90FFFFFF"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

            </LinearLayout>

        </LinearLayout>

    </FrameLayout>

    <!-- Week selector tabs -->
    <HorizontalScrollView
        android:id="@+id/week_tabs"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/header"
        android:layout_marginTop="-20dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:scrollbars="none"
        android:clipToPadding="false">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/tab_t2"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_active"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 2"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tab_t3"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 3"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tab_t4"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 4"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tab_t5"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 5"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tab_t6"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 6"
                android:textColor="@color/text_secondary"
                android:textSize="13sp"
                android:layout_marginEnd="8dp" />

            <TextView
                android:id="@+id/tab_t7"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:background="@drawable/bg_tab_inactive"
                android:gravity="center"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:text="Thứ 7"
                android:textColor="@color/text_secondary"
                android:textSize="13sp" />

        </LinearLayout>

    </HorizontalScrollView>

    <!-- Schedule content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/week_tabs"
        android:layout_marginTop="12dp"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:clipToPadding="false">

        <LinearLayout
            android:id="@+id/tkb_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Tiết 1-3 -->
            <include layout="@layout/item_tkb_slot"
                android:id="@+id/slot1" />

            <!-- Tiết 4-6 -->
            <include layout="@layout/item_tkb_slot"
                android:id="@+id/slot2" />

            <!-- Tiết 7-9 -->
            <include layout="@layout/item_tkb_slot"
                android:id="@+id/slot3" />

        </LinearLayout>

    </ScrollView>

</RelativeLayout>
