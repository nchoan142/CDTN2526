<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <FrameLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:background="@drawable/bg_gradient_header">

        <View android:layout_width="140dp" android:layout_height="140dp"
            android:layout_gravity="end|top" android:layout_marginEnd="-30dp"
            android:layout_marginTop="-30dp" android:background="@drawable/bg_splash_circle"
            android:alpha="0.12" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_gravity="center_vertical" android:layout_marginStart="8dp"
            android:layout_marginTop="16dp" android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageView android:id="@+id/btn_back" android:layout_width="48dp"
                android:layout_height="48dp" android:padding="12dp"
                android:src="@drawable/ic_arrow_back" android:contentDescription="Back"
                android:background="?attr/selectableItemBackgroundBorderless" />

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginStart="8dp" android:text="Thông Tin Khác"
                android:textColor="#FFFFFF" android:textSize="22sp" android:textStyle="bold"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>
    </FrameLayout>

    <ScrollView
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:layout_below="@id/header" android:layout_marginTop="-24dp"
        android:clipToPadding="false">

        <LinearLayout android:id="@+id/content_container"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingStart="16dp"
            android:paddingEnd="16dp" android:paddingBottom="24dp">

            <!-- Scholarships -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardCornerRadius="18dp"
                app:cardElevation="4dp" app:cardBackgroundColor="#FFFBEB">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="8dp">

                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_grade" android:layout_marginEnd="8dp"
                            android:contentDescription="Scholarship" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Học bổng" android:textColor="@color/card_bangdiem_icon"
                            android:textSize="16sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Học bổng khuyến khích học tập (GPA ≥ 3.2)\n• Học bổng tài trợ doanh nghiệp\n• Học bổng nghiên cứu khoa học\n• Hỗ trợ sinh viên hoàn cảnh khó khăn"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingExtra="5dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Clubs -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardCornerRadius="18dp"
                app:cardElevation="4dp" app:cardBackgroundColor="#EFF6FF">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="8dp">

                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_faculty" android:layout_marginEnd="8dp"
                            android:contentDescription="Club" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Câu lạc bộ" android:textColor="@color/card_truong_icon"
                            android:textSize="16sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• CLB Tin học (IT Club)\n• CLB Lập trình thi đấu (ICPC)\n• CLB Nghiên cứu AI/ML\n• CLB Khởi nghiệp công nghệ"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingExtra="5dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Activities -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginBottom="12dp" app:cardCornerRadius="18dp"
                app:cardElevation="4dp" app:cardBackgroundColor="#F0FDF4">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="18dp">

                    <LinearLayout android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:gravity="center_vertical" android:layout_marginBottom="8dp">

                        <ImageView android:layout_width="24dp" android:layout_height="24dp"
                            android:src="@drawable/ic_info" android:layout_marginEnd="8dp"
                            android:contentDescription="Activities" />

                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Hoạt động ngoại khoá" android:textColor="@color/card_khoa_icon"
                            android:textSize="16sp" android:textStyle="bold"
                            android:fontFamily="sans-serif-medium" />
                    </LinearLayout>

                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="• Olympic Tin học sinh viên toàn quốc\n• Hackathon thường niên\n• Ngày hội việc làm IT\n• Chương trình thực tập doanh nghiệp"
                        android:textColor="@color/text_secondary" android:textSize="13sp"
                        android:lineSpacingExtra="5dp" />
                </LinearLayout>
            </androidx.cardview.widget.CardView>

        </LinearLayout>
    </ScrollView>
</RelativeLayout>
